GEMINI_ANALYSIS_FALLBACK_MODELS=gemini-2.5-pro,gemini-2.5-flash
GEMINI_ANALYSIS_MAX_OUTPUT_TOKENS=12000
GEMINI_ANALYSIS_FLASH_THINKING_BUDGET=0
GEMINI_ANALYSIS_PRO_THINKING_BUDGET=128
GEMINI_BOOK_TAG_MODEL=gemini-2.5-flash
GEMINI_RECOMMENDATION_MODEL=gemini-2.5-flash
GEMINI_RECOMMENDATION_MAX_OUTPUT_TOKENS=4000
GEMINI_RECOMMENDATION_FLASH_THINKING_BUDGET=0
GEMINI_RECOMMENDATION_PRO_THINKING_BUDGET=128
